-- AdminFreeze
AdminFreeze.OnServerEvent:Connect(function(req, target)
	if not isAuthorized(req) then return end
	if not target or not target.Parent then return end
	local char = target.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	frozenPlayers[target.UserId] = not frozenPlayers[target.UserId]
	hrp.Anchored = frozenPlayers[target.UserId]
end)

-- AdminKillPlayer
AdminKillPlayer.OnServerEvent:Connect(function(req, target)
	if not isAuthorized(req) then return end
	if not target or not target.Parent then return end
	local char = target.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then hum.Health = 0 end
end)

