R_AdminJump.OnServerEvent:Connect(function(req, target, power)
    if not isAdmin(req.Name) then return end
    if not target or not target.Parent then return end
    local char = target.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.JumpPower = math.clamp(tonumber(power) or 50, 0, 500) end
end)

R_AdminBring.OnServerEvent:Connect(function(req, target, dest)
    if not isAdmin(req.Name) then return end
    if not target or not target.Parent then return end
    if not dest   or not dest.Parent   then return end
    local dHRP = dest.Character   and dest.Character:FindFirstChild("HumanoidRootPart")
    local tHRP = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if dHRP and tHRP then tHRP.CFrame = dHRP.CFrame + Vector3.new(math.random(-3,3),0,math.random(-3,3)) end
end)

R_Teleport.OnServerEvent:Connect(function(req, target, dest)
    -- Teleporte de treinamento: oficiais podem chamar
    local reqData = cache[req.UserId]
    local auth = reqData and getTeamAuth(reqData.Team) or 0
    if not isAdmin(req.Name) and auth < 3 then return end
    if not target or not target.Parent then return end
    if not dest   or not dest.Parent   then return end
    local dHRP = dest.Character   and dest.Character:FindFirstChild("HumanoidRootPart")
    local tHRP = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if dHRP and tHRP then tHRP.CFrame = dHRP.CFrame + Vector3.new(math.random(-4,4),0,math.random(-4,4)) end
end)

