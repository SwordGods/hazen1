-- Anti-DEX Explorer / Anti-Script Injector
local function setupAntiCheat()
	-- Bloqueia tentativas de explorar instâncias do servidor
	-- Verifica scripts suspeitos sendo inseridos
	local function checkSuspiciousScript(child)
		if child:IsA("LocalScript") or child:IsA("Script") or child:IsA("ModuleScript") then
			-- Scripts não autorizados fora de locais permitidos
			local allowedParents = {
				game:GetService("StarterGui"),
				game:GetService("StarterPack"),
				game:GetService("StarterPlayer"),
				game:GetService("ServerScriptService"),
				game:GetService("ReplicatedStorage"),
				game:GetService("Workspace"),
			}
			local isAllowed = false
			for _, allowed in pairs(allowedParents) do
				if child:IsDescendantOf(allowed) then
					isAllowed = true
					break
				end
			end
			-- Scripts injetados em locais errados = suspeito
			if not isAllowed then
				pcall(function() child:Destroy() end)
			end
		end
	end

	-- Monitora inserção de novos objetos no workspace
	workspace.DescendantAdded:Connect(function(child)
		pcall(checkSuspiciousScript, child)
	end)

	-- Anti-Backdoor: Verifica RemoteEvents suspeitas
	local function scanForBackdoors()
		for _, obj in pairs(game:GetDescendants()) do
			if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
				local name = obj.Name:lower()
				-- Nomes suspeitos comuns de backdoors
				local suspiciousNames = {
					"re", "rf", "evt", "event", "remote", "cmd", "exec",
					"run", "execute", "backdoor", "loader", "inject"
				}
				for _, sus in pairs(suspiciousNames) do
					if name == sus then
						-- Log suspeito mas não destroi (pode ser legítimo)
						warn("[EB-ANTICHEAT] Remote suspeita detectada: " .. obj:GetFullName())
					end
				end
			end
		end
	end

	-- Roda scan a cada 30 segundos
	coroutine.wrap(function()
		while true do
			pcall(scanForBackdoors)
			wait(30)
		end
	end)()

	-- Anti-HookFunction: Verifica integridade de funções críticas
	local originalWarn = warn
	local originalPrint = print
	local hookCheckInterval = 5

	coroutine.wrap(function()
		while true do
			-- Verifica se funções foram substituídas
			if warn ~= originalWarn then
				warn = originalWarn
			end
			wait(hookCheckInterval)
		end
	end)()
end

-- Roda anti-cheat apenas no servidor
if RunService:IsServer() then
	pcall(setupAntiCheat)
end

