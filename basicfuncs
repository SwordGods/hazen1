-- AdminMessage (exibe hint/mensagem na tela do jogador alvo)
local AdminMsgClient = getOrCreate(RemotesFolder, "RemoteEvent", "AdminMsgClient")
AdminMessage.OnServerEvent:Connect(function(req, dest, msg)
	if not isAuthorized(req) then return end
	if dest:lower() == "todos" or dest:lower() == "all" then
		for _, p in pairs(Players:GetPlayers()) do
			AdminMsgClient:FireClient(p, msg, req.Name)
		end
	else
		local tp = nil
		for _, p in pairs(Players:GetPlayers()) do
			if p.Name:lower()==dest:lower() then tp=p; break end
		end
		if tp then AdminMsgClient:FireClient(tp, msg, req.Name) end
	end
end)

-- AdminShutdown
AdminShutdown.OnServerEvent:Connect(function(req)
	if not isAuthorized(req) then return end
	print("[EB-ADMIN] Shutdown iniciado por "..req.Name)
	for _, p in pairs(Players:GetPlayers()) do
		p:Kick("🔴 O servidor foi encerrado pela administração.\nEntre novamente em breve.")
	end
end)

-- AdminBringPlayer (bring target to dest)
AdminBringPlayer.OnServerEvent:Connect(function(req, target, dest)
	if not isAuthorized(req) then return end
	if not target or not target.Parent then return end
	if not dest or not dest.Parent then return end
	local dChar = dest.Character
	local dHRP  = dChar and dChar:FindFirstChild("HumanoidRootPart")
	local tChar = target.Character
	local tHRP  = tChar and tChar:FindFirstChild("HumanoidRootPart")
	if dHRP and tHRP then
		tHRP.CFrame = dHRP.CFrame + Vector3.new(math.random(-3,3),0,math.random(-3,3))
	end
end)

