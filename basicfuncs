R_AdminMsg.OnServerEvent:Connect(function(req, dest, msg)
    if not isAdmin(req.Name) then return end
    if type(msg)~="string" or #msg>300 then return end
    local lower = (dest or ""):lower()
    if lower=="todos" or lower=="all" or lower=="" then
        for _, p in pairs(Players:GetPlayers()) do R_AdminMsgCli:FireClient(p, msg, req.Name) end
    else
        local tp = nil
        for _, p in pairs(Players:GetPlayers()) do if p.Name:lower()==lower then tp=p; break end end
        if tp then R_AdminMsgCli:FireClient(tp, msg, req.Name) end
    end
end)

