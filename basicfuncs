-- ============================================================

local function createOverhead(player, character)
    local old = character:FindFirstChild("EB_Overhead")
    if old then old:Destroy() end
    local head = character:FindFirstChild("Head")
    if not head then return end

    local bb = Instance.new("BillboardGui")
    bb.Name="EB_Overhead"; bb.Size=UDim2.new(0,220,0,75)
    bb.StudsOffset=Vector3.new(0,2.5,0); bb.AlwaysOnTop=false
    bb.MaxDistance=60; bb.Parent=head

    local bg = Instance.new("Frame")
    bg.Size=UDim2.new(1,0,1,0); bg.BackgroundColor3=Color3.fromRGB(0,0,0)
    bg.BackgroundTransparency=0.45; bg.BorderSizePixel=0; bg.Parent=bb
    local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,8); c.Parent=bg

    local function lbl(name,y,size,bold)
        local l=Instance.new("TextLabel"); l.Name=name
        l.Size=UDim2.new(1,-8,0,size or 22); l.Position=UDim2.new(0,4,0,y)
        l.BackgroundTransparency=1; l.Font=bold and Enum.Font.GothamBold or Enum.Font.GothamMedium
        l.TextSize=bold and 15 or 13; l.TextColor3=Color3.fromRGB(255,255,255)
        l.TextXAlignment=Enum.TextXAlignment.Center; l.Parent=bg; return l
    end

    lbl("NomeLabel",    2,  24, true).Text = player.DisplayName
    lbl("PatenteLabel", 26, 22, false)
    lbl("DivisaoLabel", 49, 18, false).TextSize = 11

    return bb
end

local function refreshOverhead(player)
    local data = cache[player.UserId]
    if not data then return end
    local char = player.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end
    local bb = head:FindFirstChild("EB_Overhead")
    if not bb then bb = createOverhead(player, char) end
    if not bb then return end
    local bg = bb:FindFirstChildOfClass("Frame")
    if not bg then return end
    local pL = bg:FindFirstChild("PatenteLabel")
    local dL = bg:FindFirstChild("DivisaoLabel")
    if pL then pL.Text=data.Patente; pL.TextColor3=RANK_COLOR[data.Patente] or Color3.fromRGB(200,200,200) end
    if dL then dL.Text=data.Divisao end
end

