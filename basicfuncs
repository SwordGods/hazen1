R_SetDivisao.OnServerEvent:Connect(function(requester, target, newDiv)
    local reqData = cache[requester.UserId]
    if not reqData then return end
    local auth = getTeamAuth(reqData.Team)
    if auth < 3 then return end   -- mínimo Oficial
    if not target or not target.Parent then return end
    local tgtData = cache[target.UserId]
    if not tgtData then return end
    tgtData.Divisao = newDiv or "Nenhuma"
    saveData(target, tgtData)
    local char = target.Character
    if char then
        local head = char:FindFirstChild("Head")
        if head then
            local bb = head:FindFirstChild("EB_Overhead")
            if bb then
                local bg = bb:FindFirstChildOfClass("Frame")
                local dL = bg and bg:FindFirstChild("DivisaoLabel")
                if dL then dL.Text = tgtData.Divisao end
            end
        end
    end
    R_UpdateUI:FireClient(target, tgtData)
end)

