R_SetDinheiro.OnServerEvent:Connect(function(requester, target, amount)
    if not isAdmin(requester.Name) then
        logSuspect(requester, "Tentou setar dinheiro sem ser admin.")
        return
    end
    if not target or not target.Parent then return end
    local data = cache[target.UserId]
    if not data then return end
    local v = math.max(0, math.min(tonumber(amount) or 0, 999999999))
    data.Dinheiro = v
    local ls = target:FindFirstChild("leaderstats")
    if ls and ls:FindFirstChild("Dinheiro") then ls.Dinheiro.Value = v end
    saveData(target, data)
    R_UpdateUI:FireClient(target, data)
end)

