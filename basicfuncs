-- ============================================================
-- ANTI-ABUSO — Rate limiting e log
-- ============================================================

-- Registo de ações por requester: { [userId] = { [action] = {timestamps} } }
local actionLog = {}

-- Limites: máx ações num intervalo (segundos)
local RATE_LIMITS = {
    promote  = {max=5,  window=60},   -- 5 promoções por minuto
    demote   = {max=3,  window=60},   -- 3 rebaixamentos por minuto
    recruit  = {max=5,  window=60},   -- 5 recrutamentos por minuto
    discharge= {max=3,  window=60},   -- 3 dispensas por minuto
}

local function checkRateLimit(userId, action)
    local cfg = RATE_LIMITS[action]
    if not cfg then return true end

    local now = os.time()
    actionLog[userId] = actionLog[userId] or {}
    actionLog[userId][action] = actionLog[userId][action] or {}

    -- Remove timestamps antigos
    local clean = {}
    for _, t in ipairs(actionLog[userId][action]) do
        if now - t < cfg.window then table.insert(clean, t) end
    end
    actionLog[userId][action] = clean

    if #clean >= cfg.max then return false end  -- bloqueado

    table.insert(actionLog[userId][action], now)
    return true
end

-- Log de ações suspeitas
local suspectLog = {}
local function logSuspect(player, reason)
    suspectLog[player.UserId] = (suspectLog[player.UserId] or 0) + 1
    warn(string.format("[EB-ANTIABUSOS] %s (%s) — %s [total: %d]",
        player.Name, player.UserId, reason, suspectLog[player.UserId]))
    -- Kick após 10 violações acumuladas
    if suspectLog[player.UserId] >= 10 then
        player:Kick("⛔ Você foi removido por comportamento suspeito repetido.")
    end
end

-- ============================================================
-- VALIDAÇÃO DE PERMISSÃO (coração do sistema)
-- ============================================================

--[[
    Regras:
    1. Ninguém pode se auto-promover ou se auto-rebaixar
    2. Para PROMOVER alguém, sua patente deve ser estritamente MAIOR que a do alvo
       E a patente destino deve estar dentro do seu MAX_PROMOTE_BY_TEAM
    3. Para REBAIXAR (demote), só Oficiais Superiores+ podem rebaixar (dentro da hierarquia)
       e só podem rebaixar alguém que esteja ABAIXO de si
    4. CDP > 0 bloqueia promoções (só admin ignora CDP)
    5. Admins bypass em tudo, exceto outros admins/devs (não podem rebaixar devs)
]]

local function getTeamAuth(teamName)
    return TEAM_AUTH[teamName] or 0
end

local function canActOn(requester, target, newRank, isAdminBypass)
    local reqData = cache[requester.UserId]
    local tgtData = cache[target.UserId]
    if not reqData or not tgtData then return false, "Dados não encontrados." end

    -- Não pode agir em si mesmo
    if requester.UserId == target.UserId then
        return false, "Você não pode alterar sua própria patente."
    end

    -- Não pode agir em devs (exceto outros devs)
    if isDev(target.Name) and not isDev(requester.Name) then
        return false, "Você não pode alterar a patente de um desenvolvedor."
    end

    -- Admin bypass: pode tudo (exceto devs, checado acima)
    if isAdminBypass then return true, nil end

    local reqRank    = RANK_INDEX[reqData.Patente] or 1
    local tgtRank    = RANK_INDEX[tgtData.Patente] or 1
    local newRankIdx = RANK_INDEX[newRank] or 1
    local reqTeam    = reqData.Team
    local reqAuth    = getTeamAuth(reqTeam)

    -- Precisa de pelo menos Graduados para qualquer ação
    if reqAuth < 2 then
        return false, "Você não tem autoridade suficiente."
    end

    -- Requester deve ter patente MAIOR que o alvo para agir sobre ele
    if reqRank <= tgtRank then
        return false, "Sua patente não é superior à do alvo."
    end

    -- Verifica se é promoção ou rebaixamento
    local isPromotion = newRankIdx > tgtRank
    local isDemotion  = newRankIdx < tgtRank

    if isPromotion then
        -- Verifica max de promoção pelo time
        local maxPromote = MAX_PROMOTE_BY_TEAM[reqTeam]
        if not maxPromote then
            return false, "Seu time não tem permissão de promover."
        end
        if newRankIdx > maxPromote then
            return false, "Você não pode promover até "..newRank.." (limite do seu cargo)."
        end

        -- Verifica CDP do alvo
        if (tgtData.CDP or 0) > 0 then
            return false, string.format("%s está em CDP (%d h restantes). Apenas admin pode promover.",
                target.DisplayName, tgtData.CDP)
        end

        -- Destino deve ser ACIMA do rank atual do alvo
        if newRankIdx <= tgtRank then
            return false, "Nova patente deve ser superior à atual."
        end

    elseif isDemotion then
        -- Apenas Oficiais Superiores+ podem rebaixar
        if reqAuth < 4 then
            return false, "Apenas Oficiais Superiores ou superiores podem rebaixar membros."
        end
        -- Destino deve continuar abaixo da patente do requester
        if newRankIdx >= reqRank then
            return false, "Não pode rebaixar para uma patente igual ou superior à sua."
        end
        -- Pode rebaixar até Civil (dispensa total)
    else
        -- Mesma patente: sem efeito
        return false, "A patente escolhida é a mesma que a atual."
    end

    return true, nil
end

-- ============================================================
-- APLICAR MUDANÇA DE PATENTE (função central)
-- ============================================================

local function applyRankChange(target, newRank, newDivisao, addCDP, skipCDPAdd)
    local data = cache[target.UserId]
    if not data then return false end

    local oldRank = data.Patente
    local oldTeam = data.Team
    local newTeam = RANK_TO_TEAM[newRank] or data.Team

    data.Patente = newRank
    data.Team    = newTeam

    if newDivisao ~= nil then
        data.Divisao = newDivisao ~= "" and newDivisao or data.Divisao
    end

    -- Se for promoção, adiciona 3h de CDP automaticamente
    local oldIdx = RANK_INDEX[oldRank] or 1
    local newIdx = RANK_INDEX[newRank] or 1
    if newIdx > oldIdx and not skipCDPAdd then
        data.CDP = (data.CDP or 0) + 3
    end

    -- Se virou Civil, limpa divisão
    if newRank == "Civil" then
        data.Divisao = "Nenhuma"
        data.Team    = "Civis [EB]"
    end

    -- Atualiza leaderstats
    local ls = target:FindFirstChild("leaderstats")
    if ls then
        if ls:FindFirstChild("CDP") then ls.CDP.Value = data.CDP end
    end

    -- Muda time
    local Teams = game:GetService("Teams")
    local team  = Teams:FindFirstChild(newTeam)
    if not team then
        team = Instance.new("Team")
        team.Name = newTeam
        team.AutoAssignable = false
        local colors = {
            ["Civis [EB]"]="White", ["Praças [EB]"]="Bright green",
            ["Graduados [EB]"]="Dark green", ["Oficiais [EB]"]="Bright red",
            ["Oficiais Superiores [EB]"]="Bright blue", ["Honra [EB]"]="Bright yellow",
        }
        team.TeamColor = BrickColor.new(colors[newTeam] or "Medium stone grey")
        team.Parent = Teams
    end
    target.Team = team

    -- Atualiza overhead
    local character = target.Character
    if character then
        local head = character:FindFirstChild("Head")
        if head then
            local bb = head:FindFirstChild("EB_Overhead")
            if bb then
                local bg = bb:FindFirstChildOfClass("Frame")
                if bg then
                    local pL = bg:FindFirstChild("PatenteLabel")
                    local dL = bg:FindFirstChild("DivisaoLabel")
                    if pL then pL.Text=newRank; pL.TextColor3=RANK_COLOR[newRank] or Color3.fromRGB(200,200,200) end
                    if dL then dL.Text=data.Divisao end
                end
            end
        end
    end

    -- Salva e notifica
    saveData(target, data)

    local UpdateUI = ReplicatedStorage:FindFirstChild("EBRemotes") and
                     ReplicatedStorage.EBRemotes:FindFirstChild("UpdateUI")
    if UpdateUI then UpdateUI:FireClient(target, data) end

    return true
end

