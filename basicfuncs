-- ============================================================
-- REMOTE: Punish (kick / ban)
-- ============================================================

R_Punish.OnServerEvent:Connect(function(requester, action, targetName, reason)
    if not isAdmin(requester.Name) then
        logSuspect(requester, "Tentou punir sem ser admin.")
        return
    end
    local tp = nil
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower()==(targetName or ""):lower() then tp=p; break end
    end
    if action=="kick" and tp then
        tp:Kick("⚠️ Kickado.\nMotivo: "..(reason or "N/A").."\n— [EB]")
    elseif action=="ban" then
        for _,u in pairs(UNBANNABLES) do if (targetName or ""):lower()==u:lower() then return end end
        if tp then
            banUser(tp.UserId, reason)
            tp:Kick("🔨 Banido.\nMotivo: "..(reason or "N/A").."\n— [EB]")
        end
    end
end)

