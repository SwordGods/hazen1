-- GetPlayerData: cliente pede dados de um jogador
GetPlayerDataRemote.OnServerInvoke = function(requester, targetName)
	-- Qualquer um pode ver patentes (overhead público)
	for _, p in pairs(Players:GetPlayers()) do
		if p.Name == targetName or p.DisplayName == targetName then
			return playerDataCache[p.UserId]
		end
	end
	return nil
end

-- SetPatente: chamado internamente por definitionconfigs
SetPatenteRemote.OnServerEvent:Connect(function(requester, targetPlayer, newPatente, newDivisao)
	-- Só o servidor vai chamar isso via require, clientes não devem chamar diretamente
	-- Validação: requester precisa ter permissão (checado em definitionconfigs)
	-- Por segurança, checar no cache se requester tem patente de oficial+
	local reqData = playerDataCache[requester.UserId]
	if not reqData then return end

	local authorizedTeams = {
		["Graduados [EB]"] = true,
		["Oficiais [EB]"] = true,
		["Oficiais Superiores [EB]"] = true,
		["Honra [EB]"] = true,
	}
	if not authorizedTeams[reqData.Team] then return end

	if not targetPlayer or not targetPlayer.Parent then return end

	local targetData = playerDataCache[targetPlayer.UserId]
	if not targetData then return end

	targetData.Patente = newPatente
	if newDivisao then
		targetData.Divisao = newDivisao
	end

	-- Atualiza time
	local newTeam = PATENTE_PARA_TIME[newPatente] or targetData.Team
	targetData.Team = newTeam
	setPlayerTeam(targetPlayer, newTeam)

	-- Salva
	savePlayerData(targetPlayer, targetData)

	-- Atualiza overhead
	updateOverhead(targetPlayer, newPatente, targetData.Divisao)

	-- Notifica UI do alvo
	UpdateUIRemote:FireClient(targetPlayer, targetData)
end)

-- SetDivisao
SetDivisaoRemote.OnServerEvent:Connect(function(requester, targetPlayer, newDivisao)
	local reqData = playerDataCache[requester.UserId]
	if not reqData then return end

	local authorizedTeams = {
		["Oficiais [EB]"] = true,
		["Oficiais Superiores [EB]"] = true,
		["Honra [EB]"] = true,
	}
	if not authorizedTeams[reqData.Team] then return end

	if not targetPlayer or not targetPlayer.Parent then return end
	local targetData = playerDataCache[targetPlayer.UserId]
	if not targetData then return end

	targetData.Divisao = newDivisao
	savePlayerData(targetPlayer, targetData)
	updateOverhead(targetPlayer, targetData.Patente, newDivisao)
	UpdateUIRemote:FireClient(targetPlayer, targetData)
end)

-- SetDinheiro (admin)
SetDinheiroRemote.OnServerEvent:Connect(function(requester, targetPlayer, amount)
	local reqData = playerDataCache[requester.UserId]
	if not reqData then return end
	-- Só admins (verificado via lista em definitionconfigs, aqui aceitamos confiança do servidor)
	if not targetPlayer or not targetPlayer.Parent then return end
	local targetData = playerDataCache[targetPlayer.UserId]
	if not targetData then return end

	targetData.Dinheiro = amount
	local ls = targetPlayer:FindFirstChild("leaderstats")
	if ls and ls:FindFirstChild("Dinheiro") then
		ls.Dinheiro.Value = amount
	end
	savePlayerData(targetPlayer, targetData)
	UpdateUIRemote:FireClient(targetPlayer, targetData)
end)

