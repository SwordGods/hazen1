-- ============================================================

local function createOverhead(player, character)
	-- Remove overhead antigo se existir
	local oldBill = character:FindFirstChild("EB_Overhead")
	if oldBill then oldBill:Destroy() end

	local head = character:FindFirstChild("Head")
	if not head then return end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "EB_Overhead"
	billboard.Size = UDim2.new(0, 220, 0, 75)
	billboard.StudsOffset = Vector3.new(0, 2.5, 0)
	billboard.AlwaysOnTop = false
	billboard.MaxDistance = 60
	billboard.Parent = head

	-- Fundo semi-transparente
	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	bg.BackgroundTransparency = 0.45
	bg.BorderSizePixel = 0
	bg.Parent = billboard

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = bg

	-- Label: Nome
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "NomeLabel"
	nameLabel.Size = UDim2.new(1, -8, 0, 24)
	nameLabel.Position = UDim2.new(0, 4, 0, 2)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = player.DisplayName
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextSize = 15
	nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	nameLabel.TextXAlignment = Enum.TextXAlignment.Center
	nameLabel.Parent = bg

	-- Label: Patente
	local patenteLabel = Instance.new("TextLabel")
	patenteLabel.Name = "PatenteLabel"
	patenteLabel.Size = UDim2.new(1, -8, 0, 22)
	patenteLabel.Position = UDim2.new(0, 4, 0, 26)
	patenteLabel.BackgroundTransparency = 1
	patenteLabel.Text = "Civil"
	patenteLabel.Font = Enum.Font.Gotham
	patenteLabel.TextSize = 13
	patenteLabel.TextColor3 = PATENTE_CORES["Civil"]
	patenteLabel.TextXAlignment = Enum.TextXAlignment.Center
	patenteLabel.Parent = bg

	-- Label: Divisão
	local divisaoLabel = Instance.new("TextLabel")
	divisaoLabel.Name = "DivisaoLabel"
	divisaoLabel.Size = UDim2.new(1, -8, 0, 20)
	divisaoLabel.Position = UDim2.new(0, 4, 0, 49)
	divisaoLabel.BackgroundTransparency = 1
	divisaoLabel.Text = "Nenhuma"
	divisaoLabel.Font = Enum.Font.GothamMedium
	divisaoLabel.TextSize = 11
	divisaoLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
	divisaoLabel.TextXAlignment = Enum.TextXAlignment.Center
	divisaoLabel.Parent = bg

	return billboard
end

local function updateOverhead(player, patente, divisao)
	local character = player.Character
	if not character then return end
	local head = character:FindFirstChild("Head")
	if not head then return end
	local billboard = head:FindFirstChild("EB_Overhead")
	if not billboard then
		billboard = createOverhead(player, character)
	end
	if not billboard then return end

	local bg = billboard:FindFirstChild("Frame") or billboard:FindFirstChildOfClass("Frame")
	if not bg then return end

	local pLabel = bg:FindFirstChild("PatenteLabel")
	local dLabel = bg:FindFirstChild("DivisaoLabel")
	if pLabel then
		pLabel.Text = patente or "Civil"
		pLabel.TextColor3 = PATENTE_CORES[patente] or Color3.fromRGB(200, 200, 200)
	end
	if dLabel then
		dLabel.Text = divisao or "Nenhuma"
	end
end

