-- ============================================================
-- REMOTE: SetPatente (chamado por Graduados/Oficiais/etc)
-- ============================================================

R_SetPatente.OnServerEvent:Connect(function(requester, target, newRank, newDiv)
    -- Validações básicas
    if not target or not target.Parent then return end
    if not RANK_INDEX[newRank] then
        logSuspect(requester, "Tentou setar patente inválida: "..tostring(newRank))
        return
    end

    local reqData = cache[requester.UserId]
    if not reqData then return end

    -- Determina tipo de ação para rate limit
    local tgtData   = cache[target.UserId]
    local tgtRank   = tgtData and (RANK_INDEX[tgtData.Patente] or 1) or 1
    local newRankI  = RANK_INDEX[newRank]
    local actionType = newRankI > tgtRank and "promote"
                    or newRankI < tgtRank and "demote"
                    or nil

    if not actionType then
        logSuspect(requester, "Tentou setar patente igual à atual.")
        return
    end

    -- Rate limit
    if not checkRateLimit(requester.UserId, actionType) then
        logSuspect(requester, "Rate limit excedido para "..actionType)
        warn("[EB-ANTIABUSOS] "..requester.Name.." bloqueado (rate limit "..actionType..")")
        return
    end

    -- Validação hierárquica
    local allowed, reason = canActOn(requester, target, newRank, false)
    if not allowed then
        -- Notifica o requester do erro
        local errEv = RF:FindFirstChild("NotifyError")
        if errEv then errEv:FireClient(requester, reason) end
        warn("[EB] "..requester.Name.." bloqueado: "..reason)
        logSuspect(requester, "Ação inválida: "..reason)
        return
    end

    -- Recrutamento (Civil → Recruta): graduados podem
    -- Dispensa (qualquer → Civil): apenas Oficiais Superiores+
    if newRank == "Civil" then
        local reqAuth = getTeamAuth(reqData.Team)
        if reqAuth < 4 then
            logSuspect(requester, "Tentou dispensar sem autoridade de Oficial Superior.")
            return
        end
    end

    local ok = applyRankChange(target, newRank, newDiv, true, false)
    if ok then
        print(string.format("[EB] %s → %s promovido/rebaixado para %s por %s",
            target.Name, tgtData and tgtData.Patente or "?", newRank, requester.Name))
    end
end)

