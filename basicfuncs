-- ============================================================
-- TIME DO JOGADOR
-- ============================================================

local function setPlayerTeam(player, teamName)
	local Teams = game:GetService("Teams")
	local team = Teams:FindFirstChild(teamName)
	if not team then
		-- Cria o time se não existir
		team = Instance.new("Team")
		team.Name = teamName
		team.AutoAssignable = false
		team.TeamColor = BrickColor.new("Medium stone grey")

		-- Cores por time
		local teamColors = {
			["Civis [EB]"]             = BrickColor.new("White"),
			["Praças [EB]"]            = BrickColor.new("Bright green"),
			["Graduados [EB]"]         = BrickColor.new("Dark green"),
			["Oficiais [EB]"]          = BrickColor.new("Bright red"),
			["Oficiais Superiores [EB]"]= BrickColor.new("Bright blue"),
			["Honra [EB]"]             = BrickColor.new("Bright yellow"),
		}
		team.TeamColor = teamColors[teamName] or BrickColor.new("Medium stone grey")
		team.Parent = Teams
	end
	player.Team = team
end

-- ============================================================
-- PLAYER ADDED
-- ============================================================

-- Guarda dados em memória para acesso rápido
local playerDataCache = {}

local function onPlayerAdded(player)
	-- Carrega dados
	local data = loadPlayerData(player)
	playerDataCache[player.UserId] = data

	-- Leaderstats
	setupLeaderstats(player, data)

	-- Time
	setPlayerTeam(player, data.Team or "Civis [EB]")

	-- Overhead ao spawnar
	local function onCharacterAdded(character)
		-- Espera um frame para o personagem carregar
		wait(0.1)
		createOverhead(player, character)
		-- Atualiza com dados salvos
		wait(0.2)
		updateOverhead(player, data.Patente, data.Divisao)
		-- Notifica cliente sobre dados
		UpdateUIRemote:FireClient(player, data)
	end

	player.CharacterAdded:Connect(onCharacterAdded)
	if player.Character then
		onCharacterAdded(player.Character)
	end

	-- Salva periodicamente
	coroutine.wrap(function()
		while player.Parent ~= nil do
			wait(60)
			local currentData = playerDataCache[player.UserId]
			if currentData then
				local ls = player:FindFirstChild("leaderstats")
				if ls then
					currentData.Dinheiro = ls:FindFirstChild("Dinheiro") and ls.Dinheiro.Value or currentData.Dinheiro
					currentData.CDP = ls:FindFirstChild("CDP") and ls.CDP.Value or currentData.CDP
				end
				savePlayerData(player, currentData)
			end
		end
	end)()
end

local function onPlayerRemoving(player)
	local data = playerDataCache[player.UserId]
	if data then
		local ls = player:FindFirstChild("leaderstats")
		if ls then
			data.Dinheiro = ls:FindFirstChild("Dinheiro") and ls.Dinheiro.Value or data.Dinheiro
			data.CDP = ls:FindFirstChild("CDP") and ls.CDP.Value or data.CDP
		end
		savePlayerData(player, data)
		playerDataCache[player.UserId] = nil
	end
end

