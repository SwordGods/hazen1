-- ============================================================
-- PLAYER LIFECYCLE
-- ============================================================

local function onPlayerAdded(player)
    -- Checa ban
    if isBanned(player.UserId) then
        for _,u in pairs(UNBANNABLES) do
            if u:lower()==player.Name:lower() then goto skipban end
        end
        player:Kick("❌ Você está banido.\n— Administração [EB]")
        return
        ::skipban::
    end

    local data = loadData(player)
    cache[player.UserId] = data

    setupLeaderstats(player, data)
    setTeam(player, data.Team or "Civis [EB]")

    local function onChar(char)
        task.wait(0.15)
        createOverhead(player, char)
        task.wait(0.1)
        refreshOverhead(player)
        R_UpdateUI:FireClient(player, data)
    end

    player.CharacterAdded:Connect(onChar)
    if player.Character then onChar(player.Character) end

    -- Auto-save a cada 60s
    task.spawn(function()
        while player.Parent do
            task.wait(60)
            local d = cache[player.UserId]
            if d then
                local ls = player:FindFirstChild("leaderstats")
                if ls then
                    if ls:FindFirstChild("Dinheiro") then d.Dinheiro=ls.Dinheiro.Value end
                    if ls:FindFirstChild("CDP")      then d.CDP=ls.CDP.Value end
                end
                saveData(player, d)
            end
        end
    end)
end

local function onPlayerRemoving(player)
    local d = cache[player.UserId]
    if d then
        local ls = player:FindFirstChild("leaderstats")
        if ls then
            if ls:FindFirstChild("Dinheiro") then d.Dinheiro=ls.Dinheiro.Value end
            if ls:FindFirstChild("CDP")      then d.CDP=ls.CDP.Value end
        end
        saveData(player, d)
        cache[player.UserId] = nil
    end
    actionLog[player.UserId] = nil
end

