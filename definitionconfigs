	end

	-- Tab 2: Remotes
	local t2 = tabContents[2]
	makeLabel(t2, "🔧  Remotes Registrados", UDim2.new(1,0,0,22), UDim2.new(0,0,0,0), Enum.Font.GothamBold, 15, Color3.fromRGB(200,180,255))

	local remScroll = Instance.new("ScrollingFrame")
	remScroll.Size = UDim2.new(1,0,1,-28)
	remScroll.Position = UDim2.new(0,0,0,24)
	remScroll.BackgroundTransparency = 1
	remScroll.BorderSizePixel = 0
	remScroll.ScrollBarThickness = 4
	remScroll.Parent = t2

