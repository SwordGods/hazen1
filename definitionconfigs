local function openTreinamento()
	local gui, panel, content = makePanel("🎯  Executar Treinamento", 420, 400)

	local info = makeLabel(content, "Jogadores no Treinamento:", UDim2.new(1,0,0,20), UDim2.new(0,0,0,5), Enum.Font.GothamBold, 14, Color3.fromRGB(200,220,255))
	info.TextXAlignment = Enum.TextXAlignment.Left

	local sub = makeLabel(content, "Apenas membros de Praças ou Graduados", UDim2.new(1,0,0,18), UDim2.new(0,0,0,24), Enum.Font.Gotham, 11, Color3.fromRGB(140,140,160))
	sub.TextXAlignment = Enum.TextXAlignment.Left

	-- Lista de elegíveis
	local scroll = Instance.new("ScrollingFrame")
	scroll.Size = UDim2.new(1, 0, 0, 200)
	scroll.Position = UDim2.new(0, 0, 0, 45)
	scroll.BackgroundColor3 = Color3.fromRGB(18, 18, 28)
	scroll.BorderSizePixel = 0
	scroll.ScrollBarThickness = 4
	scroll.ScrollBarImageColor3 = Color3.fromRGB(0, 120, 212)
	scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	scroll.Parent = content
	makeCorner(scroll, 8)

	local listLayout = Instance.new("UIListLayout")
	listLayout.SortOrder = Enum.SortOrder.Name
	listLayout.Parent = scroll

	local selectedPlayers = {}

	local eligibleTeams = {["Praças [EB]"] = true, ["Graduados [EB]"] = true}
	local eligibleCount = 0

	for _, p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Team and eligibleTeams[p.Team.Name] then
			eligibleCount = eligibleCount + 1
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, -4, 0, 32)
			btn.BackgroundColor3 = Color3.fromRGB(25, 25, 38)
			btn.BorderSizePixel = 0
			btn.Text = "  " .. p.DisplayName .. "  [" .. (p.Team and p.Team.Name or "?") .. "]"
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 13
			btn.TextColor3 = Color3.fromRGB(200, 220, 255)
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.AutoButtonColor = false
			btn.Parent = scroll
			makeCorner(btn, 5)

			local selected = false
			btn.MouseButton1Click:Connect(function()
				selected = not selected
				if selected then
					selectedPlayers[p.UserId] = p
					tween(btn, {BackgroundColor3 = Color3.fromRGB(0, 80, 50)}, 0.15)
					btn.TextColor3 = Color3.fromRGB(100, 255, 150)
				else
					selectedPlayers[p.UserId] = nil
					tween(btn, {BackgroundColor3 = Color3.fromRGB(25, 25, 38)}, 0.15)
					btn.TextColor3 = Color3.fromRGB(200, 220, 255)
				end
			end)
		end
	end

	scroll.CanvasSize = UDim2.new(0, 0, 0, eligibleCount * 36)

	if eligibleCount == 0 then
		local emptyLabel = makeLabel(scroll, "Nenhum membro elegível online.", UDim2.new(1,0,0,30), UDim2.new(0,0,0,10), Enum.Font.Gotham, 13, Color3.fromRGB(140,140,160))
	end

	local statusLabel = makeLabel(content, "", UDim2.new(1,0,0,20), UDim2.new(0,0,0,255), Enum.Font.Gotham, 12, Color3.fromRGB(255,100,100))

	local iniciarBtn = makeButton(content, "🚀  Iniciar Treinamento (Teleportar)", UDim2.new(1,0,0,42), UDim2.new(0,0,0,278), Color3.fromRGB(0, 130, 180))
	makeCorner(iniciarBtn, 10)

	iniciarBtn.MouseButton1Click:Connect(function()
		local count = 0
		for uid, p in pairs(selectedPlayers) do
			count = count + 1
		end
		if count == 0 then
			statusLabel.Text = "⚠️ Selecione ao menos 1 jogador!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
			return
		end

		-- Teleporta jogadores para o oficial
		local myChar = LocalPlayer.Character
		local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
		if not myHRP then
			statusLabel.Text = "❌ Não foi possível obter sua posição."
			return
		end

		local teleportRemote = RemotesFolder:FindFirstChild("TeleportToPlayer")
		if teleportRemote then
			for uid, p in pairs(selectedPlayers) do
				teleportRemote:FireServer(p, LocalPlayer)
			end
		end

		statusLabel.Text = "✅ Treinamento iniciado com " .. count .. " soldado(s)!"
		statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
	end)
end

