local function openRecrutamento()
	local gui, panel, content = makePanel("🎖️  Recrutamento Praças", 380, 260)

	local info = makeLabel(content, "Nome do Recrutado", UDim2.new(1,0,0,20), UDim2.new(0,0,0,10), Enum.Font.GothamMedium, 13, Color3.fromRGB(180,180,200))
	info.TextXAlignment = Enum.TextXAlignment.Left

	local nameBox = makeTextBox(content, "Nome do player (ex: SwordGods)", UDim2.new(1,0,0,38), UDim2.new(0,0,0,32))

	-- Status
	local statusLabel = makeLabel(content, "", UDim2.new(1,0,0,20), UDim2.new(0,0,0,80), Enum.Font.Gotham, 12, Color3.fromRGB(255, 100, 100))

	-- Botão Recrutar
	local recrutarBtn = makeButton(content, "⚔️  Recrutar", UDim2.new(1,0,0,42), UDim2.new(0,0,0,108), Color3.fromRGB(0, 130, 60))
	makeCorner(recrutarBtn, 10)

	recrutarBtn.MouseButton1Click:Connect(function()
		local nomeBuscado = nameBox.Text:match("^%s*(.-)%s*$")
		if nomeBuscado == "" then
			statusLabel.Text = "⚠️ Digite um nome!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
			return
		end

		-- Procura o jogador
		local targetPlayer = nil
		for _, p in pairs(Players:GetPlayers()) do
			if p.Name:lower() == nomeBuscado:lower() or p.DisplayName:lower() == nomeBuscado:lower() then
				targetPlayer = p
				break
			end
		end

		if not targetPlayer then
			statusLabel.Text = "❌ Jogador não encontrado no servidor!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			return
		end

		-- Busca dados do alvo
		local targetData = GetPlayerDataRemote:InvokeServer(targetPlayer.Name)

		if not targetData then
			statusLabel.Text = "❌ Não foi possível obter dados do jogador."
			statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			return
		end

		if targetData.Patente ~= "Civil" then
			statusLabel.Text = "⛔ Apenas Civis podem ser recrutados!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			return
		end

		-- Executa recrutamento
		SetPatenteRemote:FireServer(targetPlayer, "Recruta", "[EB]")
		statusLabel.Text = "✅ " .. targetPlayer.DisplayName .. " recrutado como Recruta!"
		statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)

		sendWebhook(string.format(
			"🪖 **RECRUTAMENTO** | **%s** foi recrutado como **Recruta** por **%s**",
			targetPlayer.Name, LocalPlayer.Name
		))
	end)
end

