-- Painel base com título e X
local function makePanel(title, width, height)
	local gui = Instance.new("ScreenGui")
	gui.Name = "EB_Panel_" .. title:gsub(" ", "_")
	gui.ResetOnSpawn = false
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.Parent = PlayerGui

	-- Overlay escuro
	local overlay = makeFrame(gui, UDim2.new(1,0,1,0), UDim2.new(0,0,0,0), Color3.fromRGB(0,0,0), 0.6)
	overlay.ZIndex = 1

	-- Painel principal
	local panel = makeFrame(gui, UDim2.new(0, width, 0, height), UDim2.new(0.5, -width/2, 0.5, -height/2), Color3.fromRGB(15, 15, 25))
	panel.ZIndex = 2
	makeCorner(panel, 14)
	makeStroke(panel, Color3.fromRGB(50, 50, 80), 2)

	-- Sombra
	local shadow = makeFrame(gui, UDim2.new(0, width+20, 0, height+20), UDim2.new(0.5, -(width+20)/2, 0.5, -(height+20)/2), Color3.fromRGB(0,0,0), 0.5)
	shadow.ZIndex = 1
	makeCorner(shadow, 18)

	-- Header
	local header = makeFrame(panel, UDim2.new(1,0,0,50), UDim2.new(0,0,0,0), Color3.fromRGB(0,80,160))
	header.ZIndex = 3
	makeCorner(header, 14)

	-- Arredondamento só em cima
	local headerFix = makeFrame(header, UDim2.new(1,0,0.5,0), UDim2.new(0,0,0.5,0), Color3.fromRGB(0,80,160))
	headerFix.ZIndex = 3

	-- Título
	local titleLabel = makeLabel(header, title, UDim2.new(1,-50,1,0), UDim2.new(0,15,0,0), Enum.Font.GothamBold, 18, Color3.fromRGB(255,255,255))
	titleLabel.ZIndex = 4
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left

	-- Botão X
	local closeBtn = Instance.new("TextButton")
	closeBtn.Size = UDim2.new(0, 32, 0, 32)
	closeBtn.Position = UDim2.new(1, -42, 0, 9)
	closeBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
	closeBtn.BorderSizePixel = 0
	closeBtn.Text = "✕"
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.TextSize = 16
	closeBtn.TextColor3 = Color3.fromRGB(255,255,255)
	closeBtn.AutoButtonColor = false
	closeBtn.ZIndex = 5
	closeBtn.Parent = header
	makeCorner(closeBtn, 8)

	closeBtn.MouseButton1Click:Connect(function()
		tween(panel, {Size = UDim2.new(0, width, 0, 0), Position = UDim2.new(0.5, -width/2, 0.5, 0)}, 0.25)
		wait(0.25)
		gui:Destroy()
	end)
	overlay.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			tween(panel, {Size = UDim2.new(0, width, 0, 0), Position = UDim2.new(0.5, -width/2, 0.5, 0)}, 0.25)
			wait(0.25)
			gui:Destroy()
		end
	end)

	-- Área de conteúdo
	local content = makeFrame(panel, UDim2.new(1,-20,1,-60), UDim2.new(0,10,0,55), Color3.fromRGB(15,15,25))
	content.ZIndex = 3

	-- Animação de abertura
	panel.Size = UDim2.new(0, width, 0, 0)
	panel.Position = UDim2.new(0.5, -width/2, 0.5, 0)
	tween(panel, {Size = UDim2.new(0, width, 0, height), Position = UDim2.new(0.5, -width/2, 0.5, -height/2)}, 0.3)

	return gui, panel, content, closeBtn
end

