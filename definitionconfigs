local buttonsGui = Instance.new("ScreenGui")
buttonsGui.Name = "EB_Buttons"
buttonsGui.ResetOnSpawn = false
buttonsGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
buttonsGui.Parent = PlayerGui

local buttonsContainer = Instance.new("Frame")
buttonsContainer.Name = "ButtonsContainer"
buttonsContainer.Size = UDim2.new(0, 60, 0, 400)
buttonsContainer.Position = UDim2.new(1, -70, 0.5, -200)
buttonsContainer.BackgroundTransparency = 1
buttonsContainer.BorderSizePixel = 0
buttonsContainer.Parent = buttonsGui

local function rebuildButtons(teamName)
	-- Limpa botões antigos
	for _, c in pairs(buttonsContainer:GetChildren()) do
		if c:IsA("TextButton") then c:Destroy() end
	end

	local yOffset = 0
	local isDev = false
	for _, devName in pairs(DEVELOPERS) do
		if LocalPlayer.Name == devName then isDev = true break end
	end

	local isAdmin = false
	-- Admins: verificados via lista do GitHub (simplificado: inclui devs)
	if isDev then isAdmin = true end

	local isHonra = (teamName == "Honra [EB]")
	local isOficialSup = (teamName == "Oficiais Superiores [EB]") or isHonra
	local isOficial = (teamName == "Oficiais [EB]") or isOficialSup
	local isGraduado = (teamName == "Graduados [EB]") or isOficial

	-- Botão Desenvolvedores (acima de tudo)
	if isDev then
		local devBtn = makeSideButton("🖥️", Color3.fromRGB(60, 0, 120), yOffset, buttonsContainer)
		devBtn.MouseButton1Click:Connect(openDevPanel)
		yOffset = yOffset + 58
	end

	-- Botão Admin
	if isAdmin then
		local adminBtn = makeSideButton("🔨", Color3.fromRGB(120, 30, 0), yOffset, buttonsContainer)
		adminBtn.MouseButton1Click:Connect(openAdminPanel)
		yOffset = yOffset + 58
	end

	-- Botão Oficiais Superiores / Honra: mais patentes
	if isOficialSup then
		local supBtn = makeSideButton("⭐", Color3.fromRGB(0, 40, 160), yOffset, buttonsContainer)
		supBtn.MouseButton1Click:Connect(function()
			local patentes = isHonra and PATENTES_HONRA or PATENTES_OFICIAIS_SUP
			openPromocao(patentes)
		end)
		yOffset = yOffset + 58
	end

	-- Botão Oficiais: promoção
	if isOficial and not isOficialSup then
		local ofBtn = makeSideButton("⭐", Color3.fromRGB(140, 20, 20), yOffset, buttonsContainer)
		ofBtn.MouseButton1Click:Connect(function()
			openPromocao(PATENTES_OFICIAIS)
		end)
		yOffset = yOffset + 58
	end

	-- Botão treinamento (oficiais+)
	if isOficial then
		local trainBtn = makeSideButton("🎯", Color3.fromRGB(0, 80, 80), yOffset, buttonsContainer)
		trainBtn.MouseButton1Click:Connect(openTreinamento)
		yOffset = yOffset + 58
	end

	-- Botão Graduados: recrutamento
	if isGraduado then
		local gradBtn = makeSideButton("🎖️", Color3.fromRGB(0, 80, 30), yOffset, buttonsContainer)
		gradBtn.MouseButton1Click:Connect(openRecrutamento)
		yOffset = yOffset + 58
	end
end

-- Atualiza quando o time muda
local function onTeamChanged()
	local team = LocalPlayer.Team
	rebuildButtons(team and team.Name or "Civis [EB]")
end

LocalPlayer:GetPropertyChangedSignal("Team"):Connect(onTeamChanged)
onTeamChanged()

