local function openAdminPanel()
	local gui, panel, content = makePanel("🔨  Painel de Administração", 500, 560)

	-- Tabs
	local tabNames = {"👤 Jogadores", "🏆 Patentes", "💰 Dinheiro", "🔨 Punições"}
	local tabY = 0
	local tabBtns = {}
	local tabContents = {}

	local tabBar = makeFrame(content, UDim2.new(1,0,0,38), UDim2.new(0,0,0,0), Color3.fromRGB(20,20,32))
	makeCorner(tabBar, 8)

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.FillDirection = Enum.FillDirection.Horizontal
	tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tabLayout.Parent = tabBar

	local tabArea = makeFrame(content, UDim2.new(1,0,1,-48), UDim2.new(0,0,0,44), Color3.fromRGB(18,18,28))
	makeCorner(tabArea, 8)

	local function showTab(idx)
		for i, tc in ipairs(tabContents) do
			tc.Visible = (i == idx)
		end
		for i, tb in ipairs(tabBtns) do
			tween(tb, {BackgroundColor3 = i == idx and Color3.fromRGB(0,100,200) or Color3.fromRGB(28,28,42)}, 0.2)
		end
	end

	for i, tName in ipairs(tabNames) do
		local tb = Instance.new("TextButton")
		tb.Size = UDim2.new(0, 110, 0, 34)
		tb.BackgroundColor3 = i == 1 and Color3.fromRGB(0,100,200) or Color3.fromRGB(28,28,42)
		tb.BorderSizePixel = 0
		tb.Text = tName
		tb.Font = Enum.Font.GothamMedium
		tb.TextSize = 12
		tb.TextColor3 = Color3.fromRGB(220,220,255)
		tb.AutoButtonColor = false
		tb.LayoutOrder = i
		tb.Parent = tabBar
		makeCorner(tb, 6)
		tabBtns[i] = tb

		local tc = makeFrame(tabArea, UDim2.new(1,-10,1,-10), UDim2.new(0,5,0,5), Color3.fromRGB(18,18,28))
		tc.Visible = (i == 1)
		tabContents[i] = tc

		tb.MouseButton1Click:Connect(function() showTab(i) end)
	end

	-- == Tab 1: Jogadores (lista e info) ==
	local tab1 = tabContents[1]
	local playerScroll = Instance.new("ScrollingFrame")
	playerScroll.Size = UDim2.new(1,0,1,0)
	playerScroll.BackgroundTransparency = 1
	playerScroll.BorderSizePixel = 0
	playerScroll.ScrollBarThickness = 4
	playerScroll.ScrollBarImageColor3 = Color3.fromRGB(0,120,212)
	playerScroll.CanvasSize = UDim2.new(0,0,0,0)
	playerScroll.Parent = tab1

	local pl = Instance.new("UIListLayout")
	pl.SortOrder = Enum.SortOrder.Name
	pl.Padding = UDim.new(0,4)
	pl.Parent = playerScroll

	local function refreshPlayerList()
		for _, c in pairs(playerScroll:GetChildren()) do
			if c:IsA("Frame") then c:Destroy() end
		end
		local count = 0
		for _, p in pairs(Players:GetPlayers()) do
			count = count + 1
			local row = makeFrame(playerScroll, UDim2.new(1,-4,0,40), UDim2.new(0,2,0,0), Color3.fromRGB(25,25,38))
			row.LayoutOrder = count
			makeCorner(row, 6)
			makeLabel(row, p.DisplayName, UDim2.new(0.5,0,0.5,0), UDim2.new(0,8,0,-10), Enum.Font.GothamBold, 13, Color3.fromRGB(220,220,255), Enum.TextXAlignment.Left)

			local data = GetPlayerDataRemote:InvokeServer(p.Name)
			local patente = data and data.Patente or "?"
			local divisao = data and data.Divisao or "?"
			makeLabel(row, patente .. " | " .. divisao, UDim2.new(0.5,0,0.5,0), UDim2.new(0,8,0,10), Enum.Font.Gotham, 11, PATENTE_CORES[patente] or Color3.fromRGB(180,180,200), Enum.TextXAlignment.Left)
		end
		playerScroll.CanvasSize = UDim2.new(0,0,0, count * 48)
	end
	refreshPlayerList()

	-- == Tab 2: Setagem de Patente (Admin) ==
	local tab2 = tabContents[2]
	local t2_nameBox = makeTextBox(tab2, "Nome do jogador", UDim2.new(1,0,0,36), UDim2.new(0,0,0,0))

	local allPatentes = {
		"Civil","Recruta","Soldado","Cabo",
		"Terceiro Sargento","Segundo Sargento","Primeiro Sargento","Subtenente",
		"Segundo Tenente","Primeiro Tenente","Capitao",
		"Major","Tenente Coronel","Coronel","Marechal"
	}

	local t2_pScroll = Instance.new("ScrollingFrame")
	t2_pScroll.Size = UDim2.new(1,0,1,-130)
	t2_pScroll.Position = UDim2.new(0,0,0,44)
	t2_pScroll.BackgroundColor3 = Color3.fromRGB(20,20,32)
	t2_pScroll.BorderSizePixel = 0
	t2_pScroll.ScrollBarThickness = 4
	t2_pScroll.CanvasSize = UDim2.new(0,0,0, #allPatentes * 34)
	t2_pScroll.Parent = tab2
	makeCorner(t2_pScroll, 6)

	local t2_ll = Instance.new("UIListLayout")
	t2_ll.SortOrder = Enum.SortOrder.LayoutOrder
	t2_ll.Padding = UDim.new(0,2)
	t2_ll.Parent = t2_pScroll

	local t2_selected = nil
	local t2_btns = {}

	for i, pat in ipairs(allPatentes) do
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1,-4,0,30)
		b.BackgroundColor3 = Color3.fromRGB(25,25,38)
		b.BorderSizePixel = 0
		b.Text = "  " .. pat
		b.Font = Enum.Font.Gotham
		b.TextSize = 13
		b.TextColor3 = PATENTE_CORES[pat] or Color3.fromRGB(200,200,200)
		b.TextXAlignment = Enum.TextXAlignment.Left
		b.AutoButtonColor = false
		b.LayoutOrder = i
		b.Parent = t2_pScroll
		makeCorner(b, 4)
		t2_btns[pat] = b

		b.MouseButton1Click:Connect(function()
			t2_selected = pat
			for _, bb in pairs(t2_btns) do
				tween(bb, {BackgroundColor3 = Color3.fromRGB(25,25,38)}, 0.12)
			end
			tween(b, {BackgroundColor3 = Color3.fromRGB(0,70,140)}, 0.12)
		end)
	end

	local t2_status = makeLabel(tab2, "", UDim2.new(1,0,0,20), UDim2.new(0,0,1,-65), Enum.Font.Gotham, 12, Color3.fromRGB(255,100,100))
	local t2_apply = makeButton(tab2, "✅ Aplicar Patente", UDim2.new(1,0,0,38), UDim2.new(0,0,1,-42), Color3.fromRGB(0,120,212))
	makeCorner(t2_apply, 8)

	t2_apply.MouseButton1Click:Connect(function()
		if not t2_selected then
			t2_status.Text = "⚠️ Selecione uma patente!"
			t2_status.TextColor3 = Color3.fromRGB(255,200,0)
			return
		end
		local nome = t2_nameBox.Text:match("^%s*(.-)%s*$")
		if nome == "" then
			t2_status.Text = "⚠️ Digite um nome!"
			t2_status.TextColor3 = Color3.fromRGB(255,200,0)
			return
		end
		local tp = nil
		for _, p in pairs(Players:GetPlayers()) do
			if p.Name:lower() == nome:lower() then tp = p break end
		end
		if not tp then
			t2_status.Text = "❌ Jogador não encontrado!"
			t2_status.TextColor3 = Color3.fromRGB(255,80,80)
			return
		end
		local adminRemote = RemotesFolder:FindFirstChild("AdminSetPatente")
		if adminRemote then
			adminRemote:FireServer(tp, t2_selected)
		else
			SetPatenteRemote:FireServer(tp, t2_selected, "[EB]")
		end
		t2_status.Text = "✅ Patente de " .. tp.DisplayName .. " definida: " .. t2_selected
		t2_status.TextColor3 = Color3.fromRGB(100,255,100)
	end)

	-- == Tab 3: Dinheiro ==
	local tab3 = tabContents[3]
	local t3_nameBox = makeTextBox(tab3, "Nome do jogador", UDim2.new(1,0,0,36), UDim2.new(0,0,0,0))
	local t3_amtBox = makeTextBox(tab3, "Valor (ex: 50000)", UDim2.new(1,0,0,36), UDim2.new(0,0,0,42))
	local t3_status = makeLabel(tab3, "", UDim2.new(1,0,0,20), UDim2.new(0,0,0,85), Enum.Font.Gotham, 12, Color3.fromRGB(255,100,100))

	local t3_set = makeButton(tab3, "💰 Definir Dinheiro", UDim2.new(1,0,0,38), UDim2.new(0,0,0,108), Color3.fromRGB(180,140,0))
	makeCorner(t3_set, 8)
	local t3_add = makeButton(tab3, "➕ Adicionar Dinheiro", UDim2.new(1,0,0,38), UDim2.new(0,0,0,152), Color3.fromRGB(0,140,60))
	makeCorner(t3_add, 8)
	local t3_reset = makeButton(tab3, "🔁 Resetar Dinheiro (0)", UDim2.new(1,0,0,38), UDim2.new(0,0,0,196), Color3.fromRGB(160,40,40))
	makeCorner(t3_reset, 8)

	local function getT3Values()
		local nome = t3_nameBox.Text:match("^%s*(.-)%s*$")
		local amt = tonumber(t3_amtBox.Text) or 0
		local tp = nil
		for _, p in pairs(Players:GetPlayers()) do
			if p.Name:lower() == nome:lower() then tp = p break end
		end
		return tp, amt, nome
	end

	t3_set.MouseButton1Click:Connect(function()
		local tp, amt, nome = getT3Values()
		if not tp then t3_status.Text = "❌ Jogador '" .. nome .. "' não encontrado!"; t3_status.TextColor3 = Color3.fromRGB(255,80,80); return end
		SetDinheiroRemote:FireServer(tp, amt)
		t3_status.Text = "✅ Dinheiro de " .. tp.DisplayName .. " definido: R$" .. amt
		t3_status.TextColor3 = Color3.fromRGB(100,255,100)
	end)
	t3_add.MouseButton1Click:Connect(function()
		local tp, amt = getT3Values()
		if not tp then t3_status.Text = "❌ Jogador não encontrado!"; t3_status.TextColor3 = Color3.fromRGB(255,80,80); return end
		local data = GetPlayerDataRemote:InvokeServer(tp.Name)
		local newAmt = (data and data.Dinheiro or 0) + amt
		SetDinheiroRemote:FireServer(tp, newAmt)
		t3_status.Text = "✅ +R$" .. amt .. " para " .. tp.DisplayName
		t3_status.TextColor3 = Color3.fromRGB(100,255,100)
	end)
	t3_reset.MouseButton1Click:Connect(function()
		local tp = getT3Values()
		if not tp then t3_status.Text = "❌ Jogador não encontrado!"; t3_status.TextColor3 = Color3.fromRGB(255,80,80); return end
		SetDinheiroRemote:FireServer(tp, 0)
		t3_status.Text = "✅ Dinheiro de " .. tp.DisplayName .. " zerado."
		t3_status.TextColor3 = Color3.fromRGB(100,255,100)
	end)

	-- == Tab 4: Punições ==
	local tab4 = tabContents[4]
	local t4_nameBox = makeTextBox(tab4, "Nome do jogador", UDim2.new(1,0,0,36), UDim2.new(0,0,0,0))
	local t4_reasonBox = makeTextBox(tab4, "Motivo (ban/kick)", UDim2.new(1,0,0,36), UDim2.new(0,0,0,42))
	local t4_status = makeLabel(tab4, "", UDim2.new(1,0,0,20), UDim2.new(0,0,0,85), Enum.Font.Gotham, 12, Color3.fromRGB(255,100,100))

	local t4_kick = makeButton(tab4, "👢 Kickar Jogador", UDim2.new(1,0,0,38), UDim2.new(0,0,0,108), Color3.fromRGB(160,80,0))
	makeCorner(t4_kick, 8)
	local t4_ban = makeButton(tab4, "🔨 Banir Jogador (+ Alts)", UDim2.new(1,0,0,38), UDim2.new(0,0,0,152), Color3.fromRGB(160,20,20))
	makeCorner(t4_ban, 8)

	local punishRemote = RemotesFolder:FindFirstChild("AdminPunish")

	t4_kick.MouseButton1Click:Connect(function()
		local nome = t4_nameBox.Text:match("^%s*(.-)%s*$")
		local motivo = t4_reasonBox.Text:match("^%s*(.-)%s*$")
		if nome == "" then t4_status.Text = "⚠️ Digite um nome!"; t4_status.TextColor3 = Color3.fromRGB(255,200,0); return end
		if punishRemote then
			punishRemote:FireServer("kick", nome, motivo)
			t4_status.Text = "✅ Kick enviado para " .. nome
			t4_status.TextColor3 = Color3.fromRGB(100,255,100)
		end
	end)

	t4_ban.MouseButton1Click:Connect(function()
		local nome = t4_nameBox.Text:match("^%s*(.-)%s*$")
		local motivo = t4_reasonBox.Text:match("^%s*(.-)%s*$")
		-- Verifica se é unbannable
		for _, uname in pairs(UNBANNABLES) do
			if uname:lower() == nome:lower() then
				t4_status.Text = "⛔ Esse jogador não pode ser banido!"
				t4_status.TextColor3 = Color3.fromRGB(255, 80, 80)
				return
			end
		end
		if punishRemote then
			punishRemote:FireServer("ban", nome, motivo)
			t4_status.Text = "✅ Ban enviado para " .. nome
			t4_status.TextColor3 = Color3.fromRGB(100,255,100)
		end
	end)
end

