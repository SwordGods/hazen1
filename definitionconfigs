local function openPromocao(patentesDisponiveis)
	local panelH = 100 + (#patentesDisponiveis * 36) + 130
	panelH = math.clamp(panelH, 300, 580)

	local gui, panel, content = makePanel("⭐  Promoção de Praças e Graduados", 420, panelH)

	local info = makeLabel(content, "Nome do Jogador", UDim2.new(1,0,0,20), UDim2.new(0,0,0,10), Enum.Font.GothamMedium, 13, Color3.fromRGB(180,180,200))
	info.TextXAlignment = Enum.TextXAlignment.Left

	local nameBox = makeTextBox(content, "Nome do player", UDim2.new(1,0,0,36), UDim2.new(0,0,0,32))

	-- Label de patentes
	local pLabel = makeLabel(content, "Patentes Disponíveis para Promoção:", UDim2.new(1,0,0,20), UDim2.new(0,0,0,80), Enum.Font.GothamMedium, 13, Color3.fromRGB(200,200,220))
	pLabel.TextXAlignment = Enum.TextXAlignment.Left

	-- Scroll para patentes
	local scroll = Instance.new("ScrollingFrame")
	scroll.Size = UDim2.new(1, 0, 0, math.min(#patentesDisponiveis * 36, 200))
	scroll.Position = UDim2.new(0, 0, 0, 100)
	scroll.BackgroundColor3 = Color3.fromRGB(20, 20, 32)
	scroll.BorderSizePixel = 0
	scroll.ScrollBarThickness = 4
	scroll.ScrollBarImageColor3 = Color3.fromRGB(0, 120, 212)
	scroll.CanvasSize = UDim2.new(0, 0, 0, #patentesDisponiveis * 36)
	scroll.Parent = content
	makeCorner(scroll, 8)

	local listLayout = Instance.new("UIListLayout")
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder
	listLayout.Parent = scroll

	local selectedPatente = nil
	local patenteBtns = {}

	for i, pat in ipairs(patentesDisponiveis) do
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(1, -8, 0, 32)
		btn.BackgroundColor3 = Color3.fromRGB(28, 28, 42)
		btn.BorderSizePixel = 0
		btn.Text = pat
		btn.Font = Enum.Font.GothamMedium
		btn.TextSize = 13
		btn.TextColor3 = PATENTE_CORES[pat] or Color3.fromRGB(200, 200, 200)
		btn.AutoButtonColor = false
		btn.LayoutOrder = i
		btn.Parent = scroll
		makeCorner(btn, 6)

		local leftBar = Instance.new("Frame")
		leftBar.Size = UDim2.new(0, 4, 0, 20)
		leftBar.Position = UDim2.new(0, 4, 0.5, -10)
		leftBar.BackgroundColor3 = PATENTE_CORES[pat] or Color3.fromRGB(200,200,200)
		leftBar.BorderSizePixel = 0
		leftBar.Parent = btn
		makeCorner(leftBar, 2)

		patenteBtns[pat] = btn

		btn.MouseButton1Click:Connect(function()
			-- Deseleciona todos
			for _, b in pairs(patenteBtns) do
				tween(b, {BackgroundColor3 = Color3.fromRGB(28, 28, 42)}, 0.15)
			end
			selectedPatente = pat
			tween(btn, {BackgroundColor3 = Color3.fromRGB(0, 80, 160)}, 0.15)
		end)
	end

	local yBase = 100 + math.min(#patentesDisponiveis * 36, 200) + 10
	local statusLabel = makeLabel(content, "", UDim2.new(1,0,0,20), UDim2.new(0,0,0,yBase), Enum.Font.Gotham, 12, Color3.fromRGB(255,100,100))

	local aplicarBtn = makeButton(content, "✅  Aplicar Promoção", UDim2.new(1,0,0,42), UDim2.new(0,0,0,yBase+22), Color3.fromRGB(0, 120, 212))
	makeCorner(aplicarBtn, 10)

	aplicarBtn.MouseButton1Click:Connect(function()
		if not selectedPatente then
			statusLabel.Text = "⚠️ Selecione uma patente!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
			return
		end
		local nome = nameBox.Text:match("^%s*(.-)%s*$")
		if nome == "" then
			statusLabel.Text = "⚠️ Digite um nome!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
			return
		end

		local targetPlayer = nil
		for _, p in pairs(Players:GetPlayers()) do
			if p.Name:lower() == nome:lower() or p.DisplayName:lower() == nome:lower() then
				targetPlayer = p
				break
			end
		end

		if not targetPlayer then
			statusLabel.Text = "❌ Jogador não encontrado!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			return
		end

		local targetData = GetPlayerDataRemote:InvokeServer(targetPlayer.Name)
		if not targetData then
			statusLabel.Text = "❌ Erro ao obter dados."
			statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			return
		end

		-- Civis não podem ser promovidos por oficiais (só recrutados)
		if targetData.Team == "Civis [EB]" then
			statusLabel.Text = "⛔ Civis devem ser recrutados primeiro!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			return
		end

		-- Divisão
		local divisao = "[EB]"
		SetPatenteRemote:FireServer(targetPlayer, selectedPatente, divisao)
		statusLabel.Text = "✅ " .. targetPlayer.DisplayName .. " promovido para " .. selectedPatente .. "!"
		statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)

		sendWebhook(string.format(
			"⭐ **PROMOÇÃO** | **%s** foi promovido para **%s** por **%s**",
			targetPlayer.Name, selectedPatente, LocalPlayer.Name
		))
	end)
end

